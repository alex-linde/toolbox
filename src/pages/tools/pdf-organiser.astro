---
import MainLayout from '@/layouts/MainLayout.astro';
import Breadcrumbs from '@/components/Breadcrumbs.astro';
import QuickTips from '@/components/QuickTips.astro';
import FAQAccordion from '@/components/FAQAccordion.astro';

const tips = [
  { heading: 'Load multiple PDFs', body: 'Drop several PDFs at once — all their pages appear as draggable thumbnails in one view.' },
  { heading: 'Drag to reorder',    body: 'Grab any page card and drop it in a new position to change the output order.' },
  { heading: 'Remove pages',       body: 'Click × on any thumbnail to exclude that page from the merged output.' },
  { heading: 'No uploads',         body: 'Everything runs locally. Your PDF files never leave your browser.' },
];

const faq = [
  { question: 'Can I merge pages from different PDFs?',  answer: 'Yes — load multiple PDFs and their pages appear in one flat list. Drag pages from any source to arrange the final order.' },
  { question: 'Can I reorder pages within a single PDF?', answer: 'Yes. Load a single PDF, drag its pages into the order you need, then download.' },
  { question: 'Are my files uploaded?',                  answer: 'No. All processing happens entirely in your browser using pdf-lib and PDF.js. Your files never leave your device.' },
  { question: 'Can I remove individual pages?',          answer: 'Yes — click × on any page thumbnail to exclude it from the output.' },
  { question: 'Is there a page limit?',                  answer: 'No hard limit, but PDFs with many pages will take longer to render thumbnails since all rendering runs in the browser.' },
];
---

<MainLayout
  title="PDF Organiser — Reorder, Merge & Preview Pages | Toolbox"
  description="Reorder and merge PDF pages in your browser. Drag thumbnails to rearrange, remove unwanted pages, and download a new merged PDF. No uploads."
  alpine={false}
>
  <div class="px-8 py-10 lg:px-14">

    <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
      <div>
        <Breadcrumbs tool="PDF Organiser" category="Images & Documents" />
        <h1 class="mt-3 text-2xl font-semibold tracking-tight text-slate-900">PDF Organiser</h1>
        <p class="mt-1 text-sm text-slate-500">Reorder, remove, and merge PDF pages — all in your browser.</p>
      </div>
      <button id="helpfulBtn"
        class="flex shrink-0 items-center gap-2 self-start rounded-full border border-slate-200 bg-white px-4 py-2 text-sm text-slate-500 shadow-sm transition-all hover:border-purple-200 hover:text-purple-600"
      >
        <span>👍</span><span>This helped me</span>
        <span id="helpfulCount" class="hidden font-semibold text-purple-600"></span>
      </button>
    </div>

    <div class="grid grid-cols-1 gap-8 lg:grid-cols-12">

      <div class="lg:col-span-8">
        <div class="rounded-md border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm">

          <!-- Drop zone -->
          <div id="dropZone"
            class="relative mb-6 flex cursor-pointer flex-col items-center justify-center rounded-md border-2 border-dashed border-slate-200 bg-slate-50 px-6 py-10 text-center transition-colors hover:border-purple-300 hover:bg-purple-50/30"
            role="button" tabindex="0"
          >
            <span class="mb-2 text-3xl text-slate-300" aria-hidden="true">↓</span>
            <p class="text-sm font-medium text-slate-700">Drop PDF files here</p>
            <p class="mt-1 text-xs text-slate-400">One or more PDFs accepted</p>
            <input id="fileInput" type="file" class="sr-only" accept=".pdf,application/pdf" multiple />
          </div>

          <!-- Controls bar -->
          <div id="controls" class="mb-4 hidden flex items-center justify-between">
            <span id="pageCountLabel" class="text-sm font-medium text-slate-700"></span>
            <div class="flex items-center gap-2">
              <label class="cursor-pointer rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs text-slate-600 transition-colors hover:border-purple-300">
                Add more PDFs
                <input id="addMoreInput" type="file" class="sr-only" accept=".pdf,application/pdf" multiple />
              </label>
              <button id="clearBtn"
                class="rounded-md border border-slate-200 bg-white px-3 py-1.5 text-xs text-slate-500 transition-colors hover:border-rose-200 hover:text-rose-500">
                Clear all
              </button>
            </div>
          </div>

          <!-- Page grid -->
          <div id="pageGrid" class="mb-4 flex flex-wrap gap-3" role="list" aria-label="PDF pages"></div>

          <!-- Loading bar -->
          <div id="loadingRow" class="mb-4 hidden flex items-center gap-2 text-sm text-slate-500">
            <svg class="h-4 w-4 animate-spin text-purple-500" fill="none" viewBox="0 0 24 24" aria-hidden="true">
              <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
              <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path>
            </svg>
            <span id="loadingText">Loading…</span>
          </div>

          <!-- Merge button -->
          <div id="mergeRow" hidden>
            <button id="mergeBtn"
              class="w-full rounded-md bg-gradient-to-br from-indigo-500 to-purple-500 px-6 py-3 text-sm font-semibold text-white transition-opacity disabled:opacity-50"
            >
              Merge &amp; Download
            </button>
            <p id="statusMsg" class="mt-3 hidden text-center text-sm"></p>
          </div>

        </div>
      </div>

      <aside class="lg:col-span-4">
        <div class="sticky top-8">
          <QuickTips tips={tips} />
        </div>
      </aside>

    </div>

    <!-- SEO Sandwich -->
    <div class="mt-16 rounded-md border border-slate-200 bg-slate-50 px-8 py-12">
      <div class="mx-auto max-w-2xl">
        <h2 class="mb-4 text-lg font-semibold text-slate-900">About PDF Organiser</h2>
        <p class="mb-8 text-sm leading-relaxed text-slate-600">
          Rearrange, merge, and trim PDF documents entirely in your browser. Load one or more PDF files and their
          pages appear as visual thumbnails. Drag any thumbnail to reorder it; click × to remove a page entirely.
          When your order is set, hit Merge &amp; Download to save a new PDF — no server, no uploads, no account needed.
        </p>
        <FAQAccordion items={faq} />
        <div class="mt-10 text-xs leading-relaxed text-slate-400">
          <p>Related: <a href="/tools/pdf-compress" class="text-purple-500 hover:underline">PDF Compressor</a> · <a href="/tools/file-diff" class="text-purple-500 hover:underline">File Diff</a></p>
          <p class="mt-2">Keywords: merge PDF, reorder PDF pages, combine PDF browser, rearrange PDF, delete PDF pages, PDF editor no upload</p>
        </div>
      </div>
    </div>

  </div>
</MainLayout>

<style>
  .page-card.drag-over { outline: 2px solid #a855f7; outline-offset: 2px; }
  .page-card.dragging  { opacity: 0.35; }
</style>

<script>
  import { PDFDocument } from 'pdf-lib';

  const PDFJS_CDN = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174';
  let pdfjsReady = false;

  async function loadPdfJs(): Promise<void> {
    if (pdfjsReady || (window as any).pdfjsLib) { pdfjsReady = true; return; }
    await new Promise<void>((resolve, reject) => {
      const s = document.createElement('script');
      s.src = `${PDFJS_CDN}/pdf.min.js`;
      s.onload = () => {
        (window as any).pdfjsLib.GlobalWorkerOptions.workerSrc = `${PDFJS_CDN}/pdf.worker.min.js`;
        pdfjsReady = true;
        resolve();
      };
      s.onerror = () => reject(new Error('Failed to load PDF renderer.'));
      document.head.appendChild(s);
    });
  }

  function pdfjsLib(): any { return (window as any).pdfjsLib; }

  interface PageEntry {
    id: string;
    shortName: string;
    pageIndex: number;
    pdfLibDoc: any;
    thumbUrl: string;
  }

  let pages: PageEntry[] = [];
  let nextId = 0;
  let dragSrcId: string | null = null;

  const dropZone      = document.getElementById('dropZone')!;
  const fileInput     = document.getElementById('fileInput') as HTMLInputElement;
  const addMoreInput  = document.getElementById('addMoreInput') as HTMLInputElement;
  const controlsEl    = document.getElementById('controls')!;
  const pageCountEl   = document.getElementById('pageCountLabel')!;
  const pageGrid      = document.getElementById('pageGrid')!;
  const loadingRow    = document.getElementById('loadingRow')!;
  const loadingText   = document.getElementById('loadingText')!;
  const mergeRow      = document.getElementById('mergeRow')!;
  const mergeBtn      = document.getElementById('mergeBtn') as HTMLButtonElement;
  const statusMsg     = document.getElementById('statusMsg')!;
  const clearBtn      = document.getElementById('clearBtn')!;

  // ── Drop zone ──────────────────────────────────────────────────────────────

  dropZone.addEventListener('click', () => fileInput.click());
  dropZone.addEventListener('keydown', (e: KeyboardEvent) => {
    if (e.key === 'Enter' || e.key === ' ') fileInput.click();
  });
  dropZone.addEventListener('dragover', (e: DragEvent) => {
    e.preventDefault();
    dropZone.classList.add('border-purple-400', 'bg-purple-50/50');
  });
  dropZone.addEventListener('dragleave', () => {
    dropZone.classList.remove('border-purple-400', 'bg-purple-50/50');
  });
  dropZone.addEventListener('drop', (e: DragEvent) => {
    e.preventDefault();
    dropZone.classList.remove('border-purple-400', 'bg-purple-50/50');
    const files = Array.from(e.dataTransfer?.files ?? [])
      .filter(f => f.type === 'application/pdf' || f.name.toLowerCase().endsWith('.pdf'));
    if (files.length) addFiles(files);
  });

  fileInput.addEventListener('change', () => {
    if (fileInput.files?.length) addFiles(Array.from(fileInput.files));
    fileInput.value = '';
  });
  addMoreInput.addEventListener('change', () => {
    if (addMoreInput.files?.length) addFiles(Array.from(addMoreInput.files));
    addMoreInput.value = '';
  });
  clearBtn.addEventListener('click', clearAll);

  // ── Load files ─────────────────────────────────────────────────────────────

  async function addFiles(files: File[]) {
    mergeBtn.disabled = true;
    for (const file of files) {
      try {
        await loadFile(file);
      } catch (e: any) {
        showStatus(`Failed to load "${file.name}": ${e.message}`, 'err');
      }
    }
    setLoading(false);
    updateUI();
    mergeBtn.disabled = false;
  }

  async function loadFile(file: File) {
    await loadPdfJs();
    const bytes = new Uint8Array(await file.arrayBuffer());

    const pdfLibDoc = await PDFDocument.load(bytes, { ignoreEncryption: true });
    const pdfjsDoc  = await pdfjsLib().getDocument({ data: bytes.slice() }).promise;
    const total     = pdfjsDoc.numPages;
    const shortName = file.name.replace(/\.pdf$/i, '').slice(0, 18);

    for (let i = 0; i < total; i++) {
      setLoading(true, `${file.name} — page ${i + 1} / ${total}`);
      const thumbUrl = await renderThumb(pdfjsDoc, i + 1, 108);
      const entry: PageEntry = {
        id: 'p' + nextId++,
        shortName,
        pageIndex: i,
        pdfLibDoc,
        thumbUrl,
      };
      pages.push(entry);
      appendCard(entry);
    }

    await pdfjsDoc.destroy();
  }

  async function renderThumb(doc: any, pageNum: number, targetW: number): Promise<string> {
    const page     = await doc.getPage(pageNum);
    const vp       = page.getViewport({ scale: 1 });
    const scale    = targetW / vp.width;
    const scaledVp = page.getViewport({ scale });
    const canvas   = document.createElement('canvas');
    canvas.width   = Math.round(scaledVp.width);
    canvas.height  = Math.round(scaledVp.height);
    await page.render({ canvasContext: canvas.getContext('2d')!, viewport: scaledVp }).promise;
    page.cleanup();
    return canvas.toDataURL();
  }

  // ── Page cards ─────────────────────────────────────────────────────────────

  function appendCard(entry: PageEntry) {
    const card = makeCard(entry);
    pageGrid.appendChild(card);
  }

  function makeCard(entry: PageEntry): HTMLElement {
    const card = document.createElement('div');
    card.className = 'page-card relative flex flex-col rounded-md border border-slate-200 bg-white p-1.5 cursor-grab select-none hover:border-purple-300 transition-colors';
    card.setAttribute('draggable', 'true');
    card.setAttribute('role', 'listitem');
    card.dataset.id = entry.id;

    const thumb = document.createElement('img');
    thumb.src = entry.thumbUrl;
    thumb.className = 'block w-full rounded-sm';
    card.appendChild(thumb);

    const row = document.createElement('div');
    row.className = 'mt-1.5 flex flex-col gap-1 px-0.5';

    const label = document.createElement('span');
    label.className = 'truncate text-xs text-slate-500';
    label.textContent = `${entry.shortName} · ${entry.pageIndex + 1}`;

    const btn = document.createElement('button');
    btn.className = 'w-full rounded py-0.5 text-xs font-medium text-rose-400 transition-colors hover:bg-rose-50 hover:text-rose-600';
    btn.textContent = 'Remove';
    btn.title = 'Remove this page';
    btn.addEventListener('click', (e) => { e.stopPropagation(); removePage(entry.id); });

    row.appendChild(label);
    row.appendChild(btn);
    card.appendChild(row);

    card.addEventListener('dragstart', (e: DragEvent) => {
      dragSrcId = entry.id;
      card.classList.add('dragging');
      e.dataTransfer!.effectAllowed = 'move';
    });
    card.addEventListener('dragend', () => {
      card.classList.remove('dragging');
      pageGrid.querySelectorAll('.drag-over').forEach(c => c.classList.remove('drag-over'));
    });
    card.addEventListener('dragover', (e: DragEvent) => {
      e.preventDefault();
      e.dataTransfer!.dropEffect = 'move';
      if (dragSrcId && dragSrcId !== entry.id) card.classList.add('drag-over');
    });
    card.addEventListener('dragleave', () => card.classList.remove('drag-over'));
    card.addEventListener('drop', (e: DragEvent) => {
      e.preventDefault();
      card.classList.remove('drag-over');
      if (!dragSrcId || dragSrcId === entry.id) return;
      const fromIdx = pages.findIndex(p => p.id === dragSrcId);
      const toIdx   = pages.findIndex(p => p.id === entry.id);
      if (fromIdx === -1 || toIdx === -1) return;
      const [moved] = pages.splice(fromIdx, 1);
      pages.splice(toIdx, 0, moved);
      rebuildGrid();
      dragSrcId = null;
    });

    return card;
  }

  function rebuildGrid() {
    pageGrid.innerHTML = '';
    for (const p of pages) pageGrid.appendChild(makeCard(p));
    updateCount();
  }

  function removePage(id: string) {
    const idx = pages.findIndex(p => p.id === id);
    if (idx === -1) return;
    pages.splice(idx, 1);
    pageGrid.querySelector(`[data-id="${id}"]`)?.remove();
    if (pages.length === 0) { clearAll(); return; }
    updateCount();
  }

  function clearAll() {
    pages = [];
    pageGrid.innerHTML = '';
    dropZone.classList.remove('hidden');
    controlsEl.classList.add('hidden');
    mergeRow.hidden = true;
    statusMsg.classList.add('hidden');
  }

  function updateCount() {
    pageCountEl.textContent = `${pages.length} page${pages.length !== 1 ? 's' : ''}`;
  }

  function updateUI() {
    if (!pages.length) { clearAll(); return; }
    dropZone.classList.add('hidden');
    controlsEl.classList.remove('hidden');
    mergeRow.hidden = false;
    updateCount();
  }

  function setLoading(on: boolean, msg = '') {
    loadingRow.classList.toggle('hidden', !on);
    if (on) loadingText.textContent = msg;
  }

  // ── Merge & download ───────────────────────────────────────────────────────

  mergeBtn.addEventListener('click', async () => {
    if (!pages.length) return;
    mergeBtn.disabled = true;
    showStatus('Merging…', 'info');
    try {
      const out = await PDFDocument.create();
      for (const entry of pages) {
        const [copied] = await out.copyPages(entry.pdfLibDoc, [entry.pageIndex]);
        out.addPage(copied);
      }
      const bytes    = await out.save();
      const blob     = new Blob([bytes], { type: 'application/pdf' });
      const url      = URL.createObjectURL(blob);
      const a        = document.createElement('a');
      a.href         = url;
      a.download     = pages.length === 1 ? 'reordered.pdf' : 'merged.pdf';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      setTimeout(() => URL.revokeObjectURL(url), 10_000);
      showStatus(`✓ Downloaded — ${pages.length} page${pages.length !== 1 ? 's' : ''} · ${fmtBytes(bytes.length)}`, 'ok');
    } catch (e: any) {
      showStatus('✕ ' + e.message, 'err');
    }
    mergeBtn.disabled = false;
  });

  // ── Helpful button ─────────────────────────────────────────────────────────

  document.getElementById('helpfulBtn')!.addEventListener('click', () => {
    const countEl = document.getElementById('helpfulCount')!;
    const n = parseInt(countEl.textContent || '0') + 1;
    document.getElementById('helpfulBtn')!.classList.add('border-purple-300', 'bg-purple-50', 'text-purple-600');
    countEl.textContent = String(n);
    countEl.classList.remove('hidden');
  });

  // ── Helpers ────────────────────────────────────────────────────────────────

  function fmtBytes(b: number): string {
    if (b < 1024) return b + ' B';
    if (b < 1_048_576) return (b / 1024).toFixed(1) + ' KB';
    return (b / 1_048_576).toFixed(2) + ' MB';
  }

  function showStatus(msg: string, type: 'ok' | 'err' | 'info') {
    statusMsg.textContent = msg;
    statusMsg.className = type === 'ok'
      ? 'mt-3 text-center text-sm text-emerald-600'
      : type === 'err'
        ? 'mt-3 text-center text-sm text-rose-500'
        : 'mt-3 text-center text-sm text-slate-500';
    statusMsg.classList.remove('hidden');
  }
</script>
