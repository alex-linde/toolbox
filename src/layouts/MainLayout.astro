---
import { ViewTransitions } from 'astro:transitions';
import { navCategories } from '@/data/nav';
import changelog from '../../changelog.json';
import versionData from '../../version.json';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  /** Set true on pages that use Alpine.js for tool logic */
  alpine?: boolean;
}

const {
  title,
  description,
  canonical = `https://lindetoolbox.com${Astro.url.pathname}`,
  ogTitle = title,
  ogDescription = description,
  alpine = false,
} = Astro.props;

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en" class="h-full scroll-smooth scroll-pt-16">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <title>{title}</title>
  <meta name="description" content={description} />
  <meta name="author" content="Alex Linde" />
  <meta name="robots" content="index, follow" />
  <link rel="canonical" href={canonical} />

  <meta name="theme-color" content="#7c3aed" />

  <meta property="og:type"        content="website" />
  <meta property="og:url"         content={canonical} />
  <meta property="og:title"       content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:image"       content="https://lindetoolbox.com/og.png" />
  <meta property="og:locale"      content="en_GB" />
  <meta property="og:site_name"   content="Toolbox by A.L." />

  <meta name="twitter:card"        content="summary_large_image" />
  <meta name="twitter:title"       content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image"       content="https://lindetoolbox.com/og.png" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap"
    media="print"
    onload="this.media='all'"
  />
  <noscript>
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Caveat:wght@600&family=DM+Mono:wght@400;500&family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;0,9..40,500;1,9..40,300&family=DM+Serif+Display:ital@0;1&display=swap"
    />
  </noscript>

  <!-- Alpine is imported per-page via npm (see each tool's <script>) -->

  <slot name="head" />
  <ViewTransitions />
</head>

<body class="h-full bg-slate-50 font-sans text-slate-900 antialiased">

  <!-- Header -->
  <header class="fixed inset-x-0 top-0 z-40 flex h-14 items-center border-b border-white/10 bg-sidebar">
    <div class="flex h-full w-full items-center justify-between px-5 lg:px-8">

      <!-- Left: brand -->
      <a
        href="/"
        class="text-base font-semibold text-white no-underline transition-opacity hover:opacity-80"
        aria-label="Toolbox home"
        aria-current={path === '/' ? 'page' : undefined}
      >
        Linde<em class="font-light text-purple-400 not-italic">toolbox</em>
      </a>

      <!-- Center: category nav (desktop) -->
      <nav class="hidden items-center gap-1 lg:flex" aria-label="Tool categories">
        {navCategories.map((cat) => {
          const active = cat.matches.some((m) => path.startsWith(m));
          return (
            <a
              href={cat.href}
              class:list={[
                'rounded-md px-3 py-1.5 text-sm no-underline transition-colors',
                active
                  ? 'bg-white/10 text-white'
                  : 'text-slate-400 hover:bg-white/5 hover:text-white',
              ]}
              aria-current={active ? 'page' : undefined}
            >
              {cat.label}
            </a>
          );
        })}
      </nav>

      <!-- Right: socials + coffee + version (desktop) + hamburger (mobile) -->
      <div class="flex items-center gap-3">
        <a
          href="https://github.com/alex-linde"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          data-track="gh"
          class="hidden text-slate-500 no-underline transition-colors hover:text-slate-300 lg:block"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a
          href="https://www.linkedin.com/in/iamalexlinde"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          data-track="li"
          class="hidden text-slate-500 no-underline transition-colors hover:text-slate-300 lg:block"
        >
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
        <a
          href="https://buymeacoffee.com/alexlinde"
          target="_blank"
          rel="noopener noreferrer"
          class="hidden text-xs text-slate-500 no-underline transition-colors hover:text-slate-300 lg:block"
        >
          ☕ Buy me a coffee
        </a>
        <button
          id="version-btn"
          class="hidden cursor-pointer bg-transparent text-xs text-slate-600 transition-colors hover:text-slate-400 lg:block"
          aria-label="View changelog"
        >v{versionData.version}</button>

        <!-- Mobile hamburger -->
        <button
          id="mob-open"
          class="rounded-md p-2 text-slate-400 transition-colors hover:bg-white/10 hover:text-white lg:hidden"
          aria-label="Open navigation"
          aria-expanded="false"
          aria-controls="mob-menu"
        >
          <svg class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

    </div>
  </header>

  <!-- Mobile overlay -->
  <div
    id="mob-overlay"
    class="pointer-events-none fixed inset-0 z-30 bg-black/60 opacity-0 transition-opacity duration-200 lg:hidden"
    aria-hidden="true"
  ></div>

  <!-- Mobile menu -->
  <div
    id="mob-menu"
    class="fixed inset-x-0 top-14 z-40 hidden flex-col border-b border-white/10 bg-sidebar px-5 py-4 lg:hidden"
    aria-label="Mobile navigation"
  >
    <nav class="mb-4 flex flex-col gap-0.5" aria-label="Tool categories">
      {navCategories.map((cat) => {
        const active = cat.matches.some((m) => path.startsWith(m));
        return (
          <a
            href={cat.href}
            class:list={[
              'rounded-md px-3 py-2.5 text-sm no-underline transition-colors',
              active
                ? 'bg-white/10 text-white'
                : 'text-slate-400 hover:bg-white/5 hover:text-white',
            ]}
            aria-current={active ? 'page' : undefined}
          >
            {cat.label}
          </a>
        );
      })}
    </nav>
    <div class="flex items-center justify-between border-t border-white/10 pt-4">
      <div class="flex items-center gap-4">
        <a
          href="https://buymeacoffee.com/alexlinde"
          target="_blank"
          rel="noopener noreferrer"
          class="text-xs text-slate-500 no-underline transition-colors hover:text-slate-300"
        >☕ Buy me a coffee</a>
        <a href="https://github.com/alex-linde" target="_blank" rel="noopener noreferrer" aria-label="GitHub" data-track="gh" class="text-slate-500 transition-colors hover:text-slate-300">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/iamalexlinde" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" data-track="li" class="text-slate-500 transition-colors hover:text-slate-300">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
        </a>
      </div>
      <button
        id="version-btn-mob"
        class="cursor-pointer bg-transparent text-xs text-slate-600 transition-colors hover:text-slate-400"
        aria-label="View changelog"
      >v{versionData.version}</button>
    </div>
  </div>

  <!-- Changelog modal -->
  <div id="cl-modal" class="fixed inset-0 z-[9000] hidden items-stretch justify-end" role="dialog" aria-modal="true" aria-label="Changelog">
    <div id="cl-backdrop" class="absolute inset-0 bg-slate-900/50"></div>
    <div class="relative z-10 flex w-[380px] max-w-[90vw] flex-col bg-white shadow-[-4px_0_32px_rgba(0,0,0,0.12)]">
      <div class="flex shrink-0 items-center justify-between border-b border-slate-200 px-6 py-5">
        <span class="text-sm font-semibold text-slate-900">Changelog</span>
        <button id="cl-close" class="p-1 text-slate-400 transition-colors hover:text-slate-900" aria-label="Close changelog">✕</button>
      </div>
      <div class="flex flex-1 flex-col gap-7 overflow-y-auto px-6 py-5">
        {changelog.map((entry) => (
          <div class="flex flex-col gap-2">
            <div class="flex items-baseline gap-3">
              <span class="font-mono text-[0.85rem] font-semibold text-indigo-500">v{entry.version}</span>
              <span class="font-mono text-[0.62rem] text-slate-400">{entry.date}</span>
            </div>
            <ul class="m-0 flex flex-col gap-1 pl-[1.1rem]">
              {entry.changes.map((change) => (
                <li class="text-[0.82rem] leading-relaxed text-slate-800">{change}</li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Page content -->
  <div class="flex min-h-screen flex-col pt-14">
    <slot />
  </div>

  <script is:inline>
    (function () {
      // ── Smooth scroll ────────────────────────────────────────────────────────
      var HEADER_H = 56; // matches h-14

      function easeInOut(t) {
        return t < 0.5 ? 2 * t * t : -1 + (4 - 2 * t) * t;
      }

      function smoothScrollTo(target) {
        var from = window.scrollY;
        var to   = target.getBoundingClientRect().top + window.scrollY - HEADER_H - 8;
        var dist = to - from;
        var dur  = 450;
        var t0   = null;
        function step(ts) {
          if (!t0) t0 = ts;
          var p = Math.min((ts - t0) / dur, 1);
          window.scrollTo(0, from + dist * easeInOut(p));
          if (p < 1) requestAnimationFrame(step);
        }
        requestAnimationFrame(step);
      }

      function track(key) {
        fetch('/u?k=' + key, { method: 'POST' }).catch(function () {});
      }

      // ── Per-page setup (re-runs on every View Transition) ────────────────────
      function setup() {
        var btn     = document.getElementById('mob-open');
        var menu    = document.getElementById('mob-menu');
        var overlay = document.getElementById('mob-overlay');

        function openMenu() {
          menu    && (menu.classList.remove('hidden'), menu.classList.add('flex'));
          overlay && (overlay.classList.remove('opacity-0', 'pointer-events-none'));
          btn     && btn.setAttribute('aria-expanded', 'true');
        }
        function closeMenu() {
          menu    && (menu.classList.add('hidden'), menu.classList.remove('flex'));
          overlay && (overlay.classList.add('opacity-0', 'pointer-events-none'));
          btn     && btn.setAttribute('aria-expanded', 'false');
        }

        btn && btn.addEventListener('click', function () {
          menu && menu.classList.contains('hidden') ? openMenu() : closeMenu();
        });
        overlay && overlay.addEventListener('click', closeMenu);
        menu && menu.querySelectorAll('a').forEach(function (a) {
          a.addEventListener('click', closeMenu);
        });

        // Social click tracking
        document.querySelectorAll('[data-track]').forEach(function (el) {
          el.addEventListener('click', function () { track(el.dataset.track); });
        });

        // Same-page hash scroll: intercept /#section links only when the target
        // exists in the current DOM (i.e. we are already on the home page).
        document.querySelectorAll('a[href^="/#"]').forEach(function (link) {
          link.addEventListener('click', function (e) {
            var hash   = new URL(link.href).hash;
            var target = document.getElementById(hash.slice(1));
            if (!target) return;
            e.preventDefault();
            history.pushState(null, '', '/' + hash);
            smoothScrollTo(target);
          });
        });

        // Changelog
        var modal    = document.getElementById('cl-modal');
        var backdrop = document.getElementById('cl-backdrop');
        var closeBtn = document.getElementById('cl-close');
        var vBtn     = document.getElementById('version-btn');
        var vBtnMob  = document.getElementById('version-btn-mob');

        function openCl() {
          closeMenu();
          modal && (modal.classList.remove('hidden'), modal.classList.add('flex'));
          document.body.classList.add('overflow-hidden');
        }
        function closeCl() {
          modal && (modal.classList.add('hidden'), modal.classList.remove('flex'));
          document.body.classList.remove('overflow-hidden');
        }

        vBtn     && vBtn.addEventListener('click', openCl);
        vBtnMob  && vBtnMob.addEventListener('click', openCl);
        backdrop && backdrop.addEventListener('click', closeCl);
        closeBtn && closeBtn.addEventListener('click', closeCl);
      }

      document.addEventListener('astro:page-load', setup);

      // Escape: close mobile menu or changelog (registered once, queries fresh each time).
      document.addEventListener('keydown', function (e) {
        if (e.key !== 'Escape') return;
        var modal = document.getElementById('cl-modal');
        if (modal && !modal.classList.contains('hidden')) {
          modal.classList.add('hidden');
          modal.classList.remove('flex');
          document.body.classList.remove('overflow-hidden');
        } else {
          var menu    = document.getElementById('mob-menu');
          var overlay = document.getElementById('mob-overlay');
          var btn     = document.getElementById('mob-open');
          menu    && (menu.classList.add('hidden'), menu.classList.remove('flex'));
          overlay && (overlay.classList.add('opacity-0', 'pointer-events-none'));
          btn     && btn.setAttribute('aria-expanded', 'false');
        }
      });
    }());
  </script>

</body>
</html>
